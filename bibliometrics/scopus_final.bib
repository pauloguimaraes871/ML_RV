	affiliations = {Department of Economic and Regional Development, Panteion University, 136 Syggrou Av., Athens, 176 71, Greece},
	abstract = {The task of this paper is the enhancement of realized volatility forecasts. We investigate whether a mixture of predictions (either the combination or the averaging of forecasts) can provide more accurate volatility forecasts than the forecasts of a single model. We estimate long-memory and heterogeneous autoregressive models under symmetric and asymmetric distributions for the major European Union stock market indices and the exchange rates of the Euro. The majority of models provide qualitatively similar predictions for the next trading day's volatility forecast. However, with regard to the one-week forecasting horizon, the heterogeneous autoregressive model is statistically superior to the long-memory framework. Moreover, for the two-weeks-ahead forecasting horizon, the combination of realized volatility predictions increases the forecasting accuracy and forecast averaging provides superior predictions to those supplied by a single model. Finally, the modeling of volatility asymmetry is important for the two-weeks-ahead volatility forecasts. © 2017 Elsevier Inc.},
