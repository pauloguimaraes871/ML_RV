	keywords = {Decision making; Electronic trading; Financial markets; Forecasting; Investments; Mean square error; Recurrent neural networks; Risk assessment; Specifications; Auto-regressive; Echo state networks; Heterogeneous autoregressive model; Hybrid modelling; Particle swarm; Price returns; Return volatilities; Stock price; Swarm optimization; Volatility prediction; Particle swarm optimization (PSO)},
