@ARTICLE{Yu2023,
	author = {Yu, Yuanyuan and Lin, Yu and Hou, Xianping and Zhang, Xi},
	title = {Novel optimization approach for realized volatility forecast of stock price index based on deep reinforcement learning model},
	year = {2023},
	journal = {Expert Systems with Applications},
	volume = {233},
	doi = {10.1016/j.eswa.2023.120880},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85164219954&doi=10.1016%2fj.eswa.2023.120880&partnerID=40&md5=ba12c09083a6e5fed9b3731d5b0cbff6},
	affiliations = {School of Management Science, Chengdu University of Technology, Chengdu, 610059, China; School of Business, Chengdu University of Technology, Chengdu, 610059, China; School of Statistics, Chengdu University of Information Technology, Chengdu, 610103, China},
	abstract = {Accurately predicting volatility has always been the focus of government decision-making departments, financial regulators and academia. Therefore, it is very crucial to precisely predict the realized volatility (RV) of the stock price index. In this paper, we take the RV sequences of Shanghai Stock Exchange Composite Index (SSEC), Standard & Poor 500 index (SPX) and Financial Times Stock Exchange Index (FTSE) as the research objects, and propose a predictive model based on optimized variational mode decomposition (VMD), deep learning models including deep belief network (DBN), long short-term memory network (LSTM) and gated recurrent unit (GRU), and reinforcement learning Q-learning algorithm. Firstly, the original RV sequence is decomposed by using the VMD ideal parameters optimized by grey wolf optimizer (GWO) to obtain the intrinsic mode functions (IMFs). Then, DBN, LSTM and GRU are used to predict same IMF simultaneously. Finally, the optimal weights of the above three models are determined by the Q-learning algorithm to construct an integrated model, and the final results are obtained after accumulating the predicted values of each IMF. The predictive performance of the model was evaluated by four loss functions: the mean average error (MAE), mean squared error (MSE), heterogeneous mean average error (HMAE), heterogeneous mean squared error (HMSE) and modified Diebold and Mariano test (MDM). The experimental results show that the constructed GVMD-Q-DBN-LSTM-GRU method has better performance that the comparison model in both emerging and developed markets. © 2023 Elsevier Ltd},
	author_keywords = {Deep neural network; Modified Diebold and Mariano test; Q-learning algorithm; Variational mode decomposition; Volatility forecasting},
	keywords = {Decision making; Deep neural networks; Electronic trading; Errors; Financial markets; Forecasting; Intrinsic mode functions; Learning algorithms; Learning systems; Long short-term memory; Mean square error; Reinforcement learning; Deep belief networks; Diebold; Intrinsic Mode functions; Memory network; Modified diebold and mariano test; Price index; Q-learning algorithms; Realized volatility; Stock price; Volatility forecasting; Variational mode decomposition},
	correspondence_address = {Y. Lin; School of Management Science, Chengdu University of Technology, Chengdu, 610059, China; email: linyuphd@163.com},
	publisher = {Elsevier Ltd},
	issn = {09574174},
	coden = {ESAPE},
	language = {English},
	abbrev_source_title = {Expert Sys Appl},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 29}
}

@ARTICLE{Niu20231309,
	author = {Niu, Zibo and Demirer, Riza and Suleman, Muhammad Tahir and Zhang, Hongwei},
	title = {Cross-sectional return dispersion and stock market volatility: Evidence from high-frequency data},
	year = {2023},
	journal = {Journal of Forecasting},
	volume = {42},
	number = {6},
	pages = {1309 – 1328},
	doi = {10.1002/for.2959},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85148646523&doi=10.1002%2ffor.2959&partnerID=40&md5=788efdf6439e781d435614fb389dfd43},
	affiliations = {Business School, Central South University, Changsha, 410083, China; Institute of Metal Resources Strategy, Central South University, Changsha, 410083, China; Department of Economics and Finance, Southern Illinois University Edwardsville, Edwardsville, 62026-1102, IL, United States; Department of Accounting and Finance, University of Otago, Dunedin, New Zealand; School of Mathematics and Statistics and Institute of Metal Resources Strategy, Central South University, Changsha, 410083, China},
	abstract = {This paper investigates whether the cross-sectional variance (CSV) of stock returns and its asymmetric components contain incremental information to predict stock market volatility under a high-frequency, heterogeneous autoregressive (HAR) model framework. We present novel evidence that CSV is a powerful predictor of future realized volatility, both in- and out-of-sample, even after controlling for the well-established predictors obtained from intraday data. Further analysis suggests that distinguishing between positive and negative CSV components in the forecasting model enhances the predictive capability of volatility models at all out-of-sample forecasting horizons, with the asymmetric HAR-type-ACSV model consistently outperforming all alternative HAR-type variations. We argue that the asymmetries in the predictive relation between CSV and volatility are largely driven by the disagreement among market participants that spikes during bad times. Finally, economic analysis shows that incorporating CSV in the forecasting model can generate sizeable economic gains for a mean–variance investor, suggesting that out-of-sample predictive ability of CSV can be exploited in forward looking investment strategies to enhance investment returns. © 2023 John Wiley & Sons Ltd.},
	author_keywords = {asymmetry; cross-sectional variance; HAR model; stock market; volatility forecasting},
	keywords = {Commerce; Financial markets; Forecasting; Investments; Asymmetry; Auto-regressive; Autoregressive modelling; Cross-sectional variance; Forecasting models; Heterogeneous autoregressive model; High frequency data; Stock market volatility; Stock returns; Volatility forecasting; Economic analysis},
	correspondence_address = {H. Zhang; School of Mathematics and Statistics and Institute of Metal Resources Strategy, Central South University, Changsha, 410083, China; email: hongwei@csu.edu.cn},
	publisher = {John Wiley and Sons Ltd},
	issn = {02776693},
	coden = {JOFOD},
	language = {English},
	abbrev_source_title = {J Forecast},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 6}
}

@ARTICLE{Demirer2023295,
	author = {Demirer, Riza and Gupta, Rangan and Salisu, Afees A. and van Eyden, Reneé},
	title = {Firm-level business uncertainty and the predictability of the aggregate U.S. stock market volatility during the COVID-19 pandemic},
	year = {2023},
	journal = {Quarterly Review of Economics and Finance},
	volume = {88},
	pages = {295 – 302},
	doi = {10.1016/j.qref.2023.02.002},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85148741636&doi=10.1016%2fj.qref.2023.02.002&partnerID=40&md5=f692dca22c6ae2a8e760ec3e1f0724cc},
	affiliations = {Department of Economics and Finance, Southern Illinois University Edwardsville, Edwardsville, 62026-1102, IL, United States; Department of Economics, University of Pretoria, Private Bag X20, Hatfield, 0028, South Africa; Centre for Econometrics & Applied Research, Ibadan, Nigeria},
	abstract = {In this paper, we analyze the predictive role of firm-level business expectations and uncertainties derived from a panel survey of U.S. 1750 business executives from 50 states for the realized variance (sum of daily squared log-returns over a month) of the S&P500 index over the monthly period of September 2016 to July 2021. Unlike standard models, our predictive framework adopts a time-varying approach due to the existence of multiple structural breaks in the relationship between volatility and the predictors in the model, which in turn leads to statistically insignificant causal effects in a constant parameter set-up. Our time-varying results suggest that the predictive power of firm-level business uncertainty is concentrated during the early part of the sample associated with the U.S.-China trade war and towards the end of our data coverage in the wake of the outbreak of the COVID-19 pandemic. Since in-sample predictability does not guarantee the same over an out-sample, we also conducted a full-fledged forecasting exercise to show that subjective expectations and uncertainties associated with sales growth rates and employment produce statistically significant predictability gains over January 2020 to July 2021, given an in-sample of September 2016 to December 2019. Our results suggest that subjective measures of business uncertainty at the firm level indeed capture predictive information regarding aggregate stock market uncertainty, which has important implications for investors and economic projections at the policy level. © 2023 Board of Trustees of the University of Illinois},
	author_keywords = {Firm-level expectations and uncertainties; S&P500 realized variance; Time-varying predictability},
	correspondence_address = {R. Gupta; Department of Economics, University of Pretoria, Private Bag X20, Hatfield, 0028, South Africa; email: rangan.gupta@up.ac.za},
	publisher = {Elsevier B.V.},
	issn = {10629769},
	language = {English},
	abbrev_source_title = {Q. Rev. Econ. Financ.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 3; All Open Access, Green Open Access}
}

