	publisher = {Emerald Publishing},
	issn = {17468809},
	language = {English},
	abbrev_source_title = {Int. J. Emerg. Mark.},
	type = {Article},
	publication_stage = {Article in press},
	source = {Scopus},
	note = {Cited by: 4}
}

